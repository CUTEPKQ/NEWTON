######################################################################
#  WARNING
#  ------------------------------------------------------------------
#  Template for OpenNewton's `.env` file.
#  • Do NOT commit a populated copy (with real secrets).
#  • Copy to `.env` (gitignored) and fill in your credentials.
######################################################################

# ---- Planner: the agent LLM (function-calling) ----
# Any OpenAI-compatible chat-completions endpoint.
PLANNER_API_KEY=<your-planner-api-key>
PLANNER_BASE_URL=<openai-compatible-base-url>   # e.g. https://api.openai.com/v1
PLANNER_MODEL=<planner-model-name>              # we use gpt-5.5 (any strong tool-calling LLM works)
PLANNER_AUTH=bearer                             # 'bearer' (OpenAI) or 'api-key' (Azure)

# ---- Img_create skill: image generation/editing ----
# Any OpenAI-compatible image API. See
# .claude/skills/Img_create/references/providers.md for per-provider configs.
IMG_CREATE_API=gemini                     # backend type (e.g. 'gemini' or unset for OpenAI-images)
IMG_CREATE_API_KEY=<your-api-key>
IMG_CREATE_BASE_URL=<openai-compatible-images-base-url>
IMG_CREATE_MODEL=<image-model-name>       # we use gemini-3.1-flash-image-preview

# Optional:
IMG_CREATE_AUTH_HEADER=bearer             # 'api-key' (Azure) or 'bearer' (OpenAI)
IMG_CREATE_SUPPORTED_SIZES=any            # 'any' OR comma-separated WxH list
IMG_CREATE_RESOLUTION=1280x720            # default key-frame resolution (720p)
# IMG_CREATE_OUTPUT_DIR=<dir>             # default: ./outputs/images

# ---- Seedance 2.0 video generation ----
# SEEDANCE_HOST is the video provider's hostname (no scheme), used to reach the
# Seedance-compatible /v1/videos API. Both values are required.
# We use the Seedance 2.0 model (doubao-seedance-2-0-fast-260128).
SEEDANCE_API_KEY=<your-video-api-key>
SEEDANCE_HOST=<video-provider-host>       # hostname only, e.g. api.example.com

# ---- Image_search skill: web image search ----
# Serper.dev (or any Serper-compatible /images gateway). Get a key at serper.dev.
SERPER_API_KEY=<your-serper-api-key>

# Optional:
# SERPER_BASE_URL=https://google.serper.dev  # override for a compatible gateway
# IMAGE_SEARCH_OUTPUT_DIR=<dir>              # default: ./outputs/image_search

# ---- Video verifier: Gemini video understanding ----
# Any Gemini-compatible generateContent gateway that accepts inline base64 video.
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=<gemini-multimodal-model>    # we use gemini-3.5-flash (any video-reading multimodal model)

# Optional:
# GEMINI_BASE_URL=<gemini-compatible-gateway-base-url>
